[gd_scene format=3 uid="uid://bu4ik4j52immm"]

[ext_resource type="Script" uid="uid://lb3bthdj0e38" path="res://Grid/scripts/grid_region.gd" id="1_wwy7w"]

[sub_resource type="Shader" id="Shader_yr08g"]
code = "shader_type spatial;
render_mode unshaded, depth_test_inverted;

uniform vec2 cell_size = vec2(1.0, 1.0);
uniform vec3 world_offset;
uniform float line_width = 1.5;
uniform vec4 line_color : source_color = vec4(1.0, 1.0, 1.0, 0.9);
uniform vec4 fill_color : source_color = vec4(0.3, 0.6, 1.0, 0.08);

varying vec3 world_pos;

void vertex() {
	world_pos = (MODEL_MATRIX * vec4(VERTEX, 1.0)).xyz - world_offset;
}

void fragment() {
	vec2 grid_uv = world_pos.xz / cell_size;
	vec2 uv_deriv = fwidth(grid_uv);
	vec2 grid_dist = abs(fract(grid_uv + 0.5) - 0.5);

	vec2 line_aa = uv_deriv * 0.5;
	vec2 line_alphas = 1.0 - smoothstep(uv_deriv * line_width * 0.5 - line_aa, uv_deriv * line_width * 0.5 + line_aa, grid_dist);
	float on_line = max(line_alphas.x, line_alphas.y);

	vec4 color = mix(fill_color, line_color * vec4(1.2), on_line);
	color.a = mix(fill_color.a, line_color.a, on_line);

	ALBEDO = color.rgb;
	ALPHA = color.a;
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_ailhr"]
